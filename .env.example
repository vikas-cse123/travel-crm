#####################################################################
# Interscale Travel CRM - environment template
#
# Copy to `.env` at the repo root:   cp .env.example .env
# NEVER commit a real `.env`. NEVER put production secrets here.
#####################################################################

# --- Runtime -------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# --- Networking ----------------------------------------------------
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# --- Database ------------------------------------------------------
# Must match the credentials in docker-compose.yml
POSTGRES_USER=interscale
POSTGRES_PASSWORD=interscale_dev_password
POSTGRES_DB=interscale_crm
POSTGRES_PORT=5432
DATABASE_URL=postgresql://interscale:interscale_dev_password@localhost:5432/interscale_crm?schema=public

# Integration tests run against a SEPARATE database so they never truncate dev
# data. Created automatically on first `npm run test:api`. The name must end
# with `_test` or the suite refuses to start.
TEST_DATABASE_URL=postgresql://interscale:interscale_dev_password@localhost:5432/interscale_crm_test?schema=public

# --- Sessions ------------------------------------------------------
SESSION_COOKIE_NAME=interscale_sid
# Generate a real value with: openssl rand -base64 48
SESSION_SECRET=change_me_dev_session_secret_at_least_32_chars_long
TOKEN_PEPPER=change_me_dev_token_pepper_at_least_32_chars_long
SESSION_EXPIRY_HOURS=12
REMEMBER_ME_EXPIRY_DAYS=30

# --- Email OTP verification ---------------------------------------
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- Password reset ------------------------------------------------
PASSWORD_RESET_EXPIRY_MINUTES=30

# --- Account lockout -----------------------------------------------
# Consecutive failed sign-ins before an account is temporarily locked.
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- CSRF ----------------------------------------------------------
# The double-submit CSRF token is delivered in this (JS-readable) cookie and
# echoed back in this header. Safe to expose: the token authorises nothing on
# its own. See apps/api/src/middleware/csrf.ts.
CSRF_COOKIE_NAME=interscale_csrf
CSRF_HEADER_NAME=x-csrf-token

# --- Email delivery ------------------------------------------------
# `console` prints emails (incl. dev OTP + reset link) to the API log.
#   Non-production only — env validation rejects it when NODE_ENV=production.
# `smtp`    delivers via SMTP_* below. Required in production.
# `memory`  collects mail in-process for tests only (NODE_ENV=test).
EMAIL_PROVIDER=console
EMAIL_FROM="Interscale Travel CRM <no-reply@interscale.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Rate limiting -------------------------------------------------
# Global limiter. Per-endpoint auth limiters (login, OTP, reset, …) have their
# own tighter budgets in code and are relaxed 10x outside production.
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300

# --- Frontend (Vite) -----------------------------------------------
# Only VITE_-prefixed vars are exposed to the browser bundle.
VITE_API_URL=http://localhost:4000
