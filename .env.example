#####################################################################
# Interscale Travel CRM - environment template
#
# Copy to `.env` at the repo root:   cp .env.example .env
# NEVER commit a real `.env`. NEVER put production secrets here.
#####################################################################

# --- Runtime -------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# --- Networking ----------------------------------------------------
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# --- Database ------------------------------------------------------
# Must match the credentials in docker-compose.yml
POSTGRES_USER=interscale
POSTGRES_PASSWORD=interscale_dev_password
POSTGRES_DB=interscale_crm
POSTGRES_PORT=5432
DATABASE_URL=postgresql://interscale:interscale_dev_password@localhost:5432/interscale_crm?schema=public

# --- Sessions ------------------------------------------------------
SESSION_COOKIE_NAME=interscale_sid
# Generate a real value with: openssl rand -base64 48
SESSION_SECRET=change_me_dev_session_secret_at_least_32_chars_long
TOKEN_PEPPER=change_me_dev_token_pepper_at_least_32_chars_long
SESSION_EXPIRY_HOURS=12
REMEMBER_ME_EXPIRY_DAYS=30

# --- Email OTP verification ---------------------------------------
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- Password reset ------------------------------------------------
PASSWORD_RESET_EXPIRY_MINUTES=30

# --- Email delivery ------------------------------------------------
# `console` prints emails (incl. dev OTP) to the API log. Non-production only.
EMAIL_PROVIDER=console
EMAIL_FROM="Interscale Travel CRM <no-reply@interscale.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Rate limiting -------------------------------------------------
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300

# --- Frontend (Vite) -----------------------------------------------
# Only VITE_-prefixed vars are exposed to the browser bundle.
VITE_API_URL=http://localhost:4000
