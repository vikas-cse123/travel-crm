  durationDays             Int
  durationNights           Int
  baseCurrency             String                  @default("INR") @db.VarChar(3)
  adultBasePrice           Decimal?                @db.Decimal(14, 2)
  childWithBedBasePrice    Decimal?                @db.Decimal(14, 2)
  childWithoutBedBasePrice Decimal?                @db.Decimal(14, 2)
  infantBasePrice          Decimal?                @db.Decimal(14, 2)
  status                   QuotationTemplateStatus @default(ACTIVE)
  usageCount               Int                     @default(0)
  internalNotes            String?                 @db.VarChar(4000)
  createdById              String                  @db.Uuid
