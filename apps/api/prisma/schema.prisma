// Interscale Travel CRM — multi-tenant domain schema (Phase 2)
//
// TENANCY MODEL
// Every travel agency is one `Company` row. Company-owned tables carry an
// explicit `companyId`; credential tables (Session, EmailVerificationOtp,
// PasswordResetToken) inherit tenancy through their `User`, which is why they
// do not repeat the column — a denormalised copy could drift out of sync with
// the user's real owner and become a silent isolation hole.
//
// ROW-LEVEL SECURITY
// PostgreSQL RLS is deliberately NOT used. Enforcing it requires a
// transaction-scoped `SET LOCAL app.company_id` on every query, which is
// unreliable across Prisma's connection pool and interactive transactions, and
// fails *open* when it is missed. Isolation is instead enforced by the typed
// tenant-scoped repositories in `src/modules/**/*.repository.ts`, where
// `companyId` is a required parameter, and is covered by cross-tenant tests in
// `tests/tenant-isolation.test.ts`.
//
// SOFT DELETION
// `User` and `PermissionTemplate` use `deletedAt`. Unique constraints
// intentionally still count soft-deleted rows: releasing an archived user's
// email would let a new account claim it and make restoring the original
// impossible. Freeing an identifier is therefore an explicit anonymisation
// step, not an implicit side effect of archiving.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

