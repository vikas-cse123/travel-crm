model Query {
  id                       String                   @id @default(uuid()) @db.Uuid
  companyId                String                   @db.Uuid
  customerId               String?                  @db.Uuid
  queryNumber              String                   @db.VarChar(24)
  customerName             String                   @db.VarChar(120)
  phone                    String                   @db.VarChar(32)
  normalizedPhone          String                   @db.VarChar(24)
  alternatePhone           String?                  @db.VarChar(32)
  email                    String?                  @db.VarChar(255)
  dateOfBirth              DateTime?                @db.Date
  leadSource               LeadSource
  leadType                 LeadType                 @default(FRESH)
  leadStage                LeadStage                @default(NEW_LEAD)
  priority                 QueryPriority            @default(MEDIUM)
  departureCountry         String?                  @db.VarChar(80)
  departureCity            String?                  @db.VarChar(100)
  travelStartDate          DateTime?                @db.Date
  travelEndDate            DateTime?                @db.Date
  flexibleDates            Boolean                  @default(false)
  rooms                    Int                      @default(1)
  adults                   Int                      @default(1)
  childrenWithBed          Int                      @default(0)
  childrenWithoutBed       Int                      @default(0)
  infants                  Int                      @default(0)
  extraBeds                Int                      @default(0)
  travellerSummary         String                   @db.VarChar(255)
  expectedAmount           Decimal?                 @db.Decimal(14, 2)
  budgetMin                Decimal?                 @db.Decimal(14, 2)
  budgetMax                Decimal?                 @db.Decimal(14, 2)
  expectedMargin           Decimal?                 @db.Decimal(14, 2)
  currency                 String                   @default("INR") @db.VarChar(3)
  tripType                 String?                  @db.VarChar(40)
  quotationRequired        Boolean                  @default(false)
  bookingStatusPlaceholder String?                  @db.VarChar(80)
  webLinkPlaceholder       String?                  @db.VarChar(500)
  supplierCostingNotes     String?                  @db.VarChar(2000)
  assignedToId             String?                  @db.Uuid
  createdById              String                   @db.Uuid
  lastContactedAt          DateTime?
  nextFollowUpAt           DateTime?
  lostReason               String?                  @db.VarChar(500)
  convertedAt              DateTime?
  internalRemarks          String?                  @db.VarChar(2000)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  deletedAt                DateTime?
  company                  Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer                 Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo               User?                    @relation("QueryAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy                User                     @relation("QueryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  notes                    QueryNote[]
  stageHistory             QueryStageHistory[]
  assignmentHistory        QueryAssignmentHistory[]
  followUps                QueryFollowUp[]
  services                 QueryService[]
  itinerary                QueryItinerary[]
  quotations               Quotation[]
  bookings                 Booking[]
  customerCommunications   CustomerCommunication[]

  @@unique([companyId, queryNumber])
  @@index([companyId, normalizedPhone])
  @@index([companyId, customerId, deletedAt])
  @@index([companyId, leadStage, deletedAt])
  @@index([companyId, leadType, deletedAt])
  @@index([companyId, priority, deletedAt])
  @@index([companyId, assignedToId, deletedAt])
  @@index([companyId, nextFollowUpAt])
  @@index([companyId, travelStartDate])
  @@index([companyId, createdAt])
  @@map("queries")
}

