model QuotationTemplate {
  id                       String                  @id @default(uuid()) @db.Uuid
  companyId                String                  @db.Uuid
  templateCode             String                  @db.VarChar(24)
  name                     String                  @db.VarChar(160)
  description              String?                 @db.VarChar(4000)
