model Quotation {
  id                   String          @id @default(uuid()) @db.Uuid
  companyId            String          @db.Uuid
  customerId           String?         @db.Uuid
  quotationNumber      String          @db.VarChar(24)
  queryId              String          @db.Uuid
  sourceTemplateId     String?         @db.Uuid
  createdById          String          @db.Uuid
  currentVersionId     String?         @db.Uuid
  acceptedVersionId    String?         @db.Uuid
  publicVersionId      String?         @db.Uuid
  status               QuotationStatus @default(DRAFT)
  customerName         String          @db.VarChar(120)
  customerEmail        String?         @db.VarChar(255)
  customerPhone        String          @db.VarChar(32)
  destinationSummary   String          @db.VarChar(500)
  travelStartDate      DateTime?       @db.Date
  travelEndDate        DateTime?       @db.Date
  adults               Int             @default(1)
  childrenWithBed      Int             @default(0)
  childrenWithoutBed   Int             @default(0)
  infants              Int             @default(0)
  rooms                Int             @default(1)
  currency             String          @default("INR") @db.VarChar(3)
  validUntil           DateTime?       @db.Date
  publicTokenHash      String?         @unique @db.VarChar(64)
  publicTokenExpiresAt DateTime?
  firstSentAt          DateTime?
  lastSentAt           DateTime?
  firstViewedAt        DateTime?
  lastViewedAt         DateTime?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  rejectionReason      String?         @db.VarChar(2000)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  query          Query               @relation(fields: [queryId], references: [id], onDelete: Restrict)
  sourceTemplate QuotationTemplate?  @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  createdBy      User                @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  versions       QuotationVersion[]
  documents      QuotationDocument[]
  emailLogs      QuotationEmailLog[]
  booking        Booking?

  @@unique([companyId, quotationNumber])
  @@index([companyId, queryId, deletedAt])
  @@index([companyId, customerId, deletedAt])
  @@index([companyId, status, deletedAt])
  @@index([companyId, createdById, deletedAt])
  @@index([companyId, validUntil])
  @@map("quotations")
}

model QuotationVersion {
  id                   String                 @id @default(uuid()) @db.Uuid
  companyId            String                 @db.Uuid
  quotationId          String                 @db.Uuid
  versionNumber        Int
  title                String                 @db.VarChar(200)
  introduction         String?                @db.VarChar(4000)
  destinationSummary   String                 @db.VarChar(500)
  travelStartDate      DateTime?              @db.Date
  travelEndDate        DateTime?              @db.Date
  currency             String                 @db.VarChar(3)
  subtotalCost         Decimal                @default(0) @db.Decimal(14, 2)
  subtotalSellingPrice Decimal                @default(0) @db.Decimal(14, 2)
  markupMode           MarkupMode             @default(NONE)
  markupValue          Decimal                @default(0) @db.Decimal(14, 4)
  totalMarkup          Decimal                @default(0) @db.Decimal(14, 2)
  taxRate              Decimal                @default(0) @db.Decimal(8, 4)
  taxAmount            Decimal                @default(0) @db.Decimal(14, 2)
  discountAmount       Decimal                @default(0) @db.Decimal(14, 2)
  finalAmount          Decimal                @default(0) @db.Decimal(14, 2)
  marginAmount         Decimal                @default(0) @db.Decimal(14, 2)
  marginPercentage     Decimal                @default(0) @db.Decimal(8, 4)
  pricingMode          PricingMode            @default(ITEMIZED)
  notes                String?                @db.VarChar(4000)
  internalNotes        String?                @db.VarChar(4000)
  status               QuotationVersionStatus @default(DRAFT)
  finalizedAt          DateTime?
  createdById          String                 @db.Uuid
  createdAt            DateTime               @default(now())

  company    Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotation  Quotation                      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  createdBy  User                           @relation("QuotationVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  itinerary  QuotationVersionItineraryDay[]
  hotels     QuotationVersionHotelOption[]
  services   QuotationVersionService[]
  inclusions QuotationVersionInclusion[]
  exclusions QuotationVersionExclusion[]
  terms      QuotationVersionTerm[]
  documents  QuotationDocument[]
  emailLogs  QuotationEmailLog[]
  booking    Booking?

  @@unique([quotationId, versionNumber])
  @@index([companyId, quotationId])
  @@map("quotation_versions")
}

