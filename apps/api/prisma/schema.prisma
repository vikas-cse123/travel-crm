model BookingPayment {
  id                String              @id @default(uuid()) @db.Uuid
  companyId         String              @db.Uuid
  bookingId         String              @db.Uuid
  paymentScheduleId String?             @db.Uuid
  paymentNumber     String              @db.VarChar(24)
  amount            Decimal             @db.Decimal(14, 2)
  currency          String              @db.VarChar(3)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentRecordStatus @default(RECEIVED)
  receivedAt        DateTime
  referenceNumber   String?             @db.VarChar(255)
  bankName          String?             @db.VarChar(200)
  notes             String?             @db.VarChar(2000)
  recordedById      String              @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reversedAt        DateTime?
  reversedById      String?             @db.Uuid
  reversalReason    String?             @db.VarChar(2000)

  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking         Booking                 @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  paymentSchedule BookingPaymentSchedule? @relation(fields: [paymentScheduleId], references: [id], onDelete: Restrict)
  recordedBy      User                    @relation("BookingPaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  reversedBy      User?                   @relation("BookingPaymentReversedBy", fields: [reversedById], references: [id], onDelete: Restrict)
  documents       BookingDocument[]

  @@unique([companyId, paymentNumber])
  @@index([companyId, bookingId, createdAt])
  @@index([companyId, paymentScheduleId])
  @@map("booking_payments")
}

model BookingCost {
  id                String              @id @default(uuid()) @db.Uuid
  companyId         String              @db.Uuid
  bookingId         String              @db.Uuid
  bookingServiceId  String?             @db.Uuid
  costCategory      BookingCostCategory
  supplierName      String              @db.VarChar(200)
  supplierReference String?             @db.VarChar(255)
  description       String              @db.VarChar(1000)
  amount            Decimal             @db.Decimal(14, 2)
  currency          String              @db.VarChar(3)
  costStatus        BookingCostStatus   @default(ESTIMATED)
  dueDate           DateTime?           @db.Date
  paidAt            DateTime?
  paymentReference  String?             @db.VarChar(255)
  notes             String?             @db.VarChar(2000)
  recordedById      String              @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  bookingService BookingService? @relation(fields: [bookingServiceId], references: [id], onDelete: SetNull)
  recordedBy     User            @relation("BookingCostRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([companyId, bookingId, deletedAt])
  @@index([companyId, dueDate, costStatus])
  @@map("booking_costs")
}

model BookingDocument {
  id               String              @id @default(uuid()) @db.Uuid
  companyId        String              @db.Uuid
  bookingId        String              @db.Uuid
  travellerId      String?             @db.Uuid
  bookingServiceId String?             @db.Uuid
  paymentId        String?             @db.Uuid
  documentType     BookingDocumentType
  storageProvider  StorageProvider
  bucket           String              @db.VarChar(255)
  objectKey        String              @db.VarChar(1000)
  fileName         String              @db.VarChar(255)
  originalFileName String              @db.VarChar(255)
  mimeType         String              @db.VarChar(120)
  fileSize         Int
  checksum         String?             @db.VarChar(128)
  uploadStatus     DocumentStatus      @default(PENDING)
  visibility       DocumentVisibility  @default(INTERNAL)
  expiresAt        DateTime?
  uploadedById     String              @db.Uuid
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking        Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  traveller      BookingTraveller? @relation(fields: [travellerId], references: [id], onDelete: Restrict)
  bookingService BookingService?   @relation(fields: [bookingServiceId], references: [id], onDelete: Restrict)
  payment        BookingPayment?   @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  uploadedBy     User              @relation("BookingDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@unique([companyId, objectKey])
  @@index([companyId, bookingId, deletedAt])
  @@index([companyId, travellerId, deletedAt])
  @@index([companyId, bookingServiceId, deletedAt])
  @@index([companyId, paymentId, deletedAt])
  @@map("booking_documents")
}

model BookingNote {
  id           String          @id @default(uuid()) @db.Uuid
  companyId    String          @db.Uuid
  bookingId    String          @db.Uuid
  authorUserId String          @db.Uuid
  content      String          @db.VarChar(4000)
  noteType     BookingNoteType @default(GENERAL)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorUser User    @relation("BookingNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([companyId, bookingId, createdAt])
  @@map("booking_notes")
}

model BookingStatusHistory {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @db.Uuid
  bookingId      String         @db.Uuid
  previousStatus BookingStatus?
  newStatus      BookingStatus
  changedById    String         @db.Uuid
  reason         String?        @db.VarChar(2000)
  createdAt      DateTime       @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("BookingStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([companyId, bookingId, createdAt])
  @@map("booking_status_history")
}

model BookingAssignmentHistory {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @db.Uuid
  bookingId          String   @db.Uuid
  previousAssigneeId String?  @db.Uuid
  newAssigneeId      String?  @db.Uuid
  assignedById       String   @db.Uuid
  createdAt          DateTime @default(now())

  company          Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking          Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  previousAssignee User?   @relation("BookingPreviousAssignee", fields: [previousAssigneeId], references: [id], onDelete: SetNull)
  newAssignee      User?   @relation("BookingNewAssignee", fields: [newAssigneeId], references: [id], onDelete: SetNull)
  assignedBy       User    @relation("BookingAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@index([companyId, bookingId, createdAt])
  @@map("booking_assignment_history")
}

model BookingEmailLog {
  id                String              @id @default(uuid()) @db.Uuid
  companyId         String              @db.Uuid
  bookingId         String              @db.Uuid
  emailType         BookingEmailType
  recipientEmail    String              @db.VarChar(255)
  subject           String              @db.VarChar(255)
  providerMessageId String?             @db.VarChar(255)
  status            EmailDeliveryStatus @default(PENDING)
  failureReason     String?             @db.VarChar(2000)
  sentById          String              @db.Uuid
  sentAt            DateTime?
