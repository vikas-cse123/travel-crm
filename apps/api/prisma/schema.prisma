// ---------------------------------------------------------------------------
// Tenant root
// ---------------------------------------------------------------------------

/// A travel agency. The tenant boundary for every other table.
model Company {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(120)
  /// URL-safe identifier derived from the name. Globally unique.
  slug          String        @unique @db.VarChar(140)
  email         String        @db.VarChar(255)
  phone         String?       @db.VarChar(32)
  website       String?       @db.VarChar(255)
  address       String?       @db.VarChar(1000)
  primaryColor  String        @default("#2563eb") @db.VarChar(7)
  logoObjectKey String?       @db.VarChar(1000)
  status        CompanyStatus @default(ACTIVE)
  timezone      String        @default("Asia/Kolkata") @db.VarChar(64)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                        User[]
  roles                        Role[]
  permissionTemplates          PermissionTemplate[]
  activityLogs                 ActivityLog[]
  queries                      Query[]
  queryCounters                QueryCounter[]
  queryNotes                   QueryNote[]
  queryStageHistory            QueryStageHistory[]
  queryAssignments             QueryAssignmentHistory[]
  queryFollowUps               QueryFollowUp[]
  queryServices                QueryService[]
