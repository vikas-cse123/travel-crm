}

// ---------------------------------------------------------------------------
// Phase 13A — Cities and destinations masters
// ---------------------------------------------------------------------------

model City {
  id             String       @id @default(uuid()) @db.Uuid
  companyId      String       @db.Uuid
  countryCode    String       @db.Char(2)
  countryName    String       @db.VarChar(120)
  name           String       @db.VarChar(160)
  normalizedName String       @db.VarChar(160)
  airportCode    String?      @db.VarChar(3)
  status         MasterStatus @default(ACTIVE)
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("CityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  destinationLinks DestinationCity[]
  hotels           Hotel[]
  sightseeings     Sightseeing[]

  @@index([companyId, countryCode, normalizedName])
  @@index([companyId, status, deletedAt])
  @@index([companyId, airportCode])
  @@index([createdById])
  @@map("cities")
}

model Destination {
  id                    String           @id @default(uuid()) @db.Uuid
  companyId             String           @db.Uuid
  countryCode           String           @db.Char(2)
  countryName           String           @db.VarChar(120)
  name                  String           @db.VarChar(200)
  normalizedName        String           @db.VarChar(200)
  destinationType       DestinationType
  imageStorageProvider  StorageProvider?
  imageBucket           String?          @db.VarChar(255)
  imageObjectKey        String?          @db.VarChar(1000)
  imageFileName         String?          @db.VarChar(255)
  imageMimeType         String?          @db.VarChar(120)
  imageFileSize         Int?
  imageConfirmedAt      DateTime?
  pendingImageObjectKey String?          @db.VarChar(1000)
  pendingImageFileName  String?          @db.VarChar(255)
  pendingImageMimeType  String?          @db.VarChar(120)
  pendingImageFileSize  Int?
  inclusions            String?          @db.Text
  exclusions            String?          @db.Text
  paymentPolicies       String?          @db.Text
  cancellationPolicies  String?          @db.Text
  bookingTerms          String?          @db.Text
  status                MasterStatus     @default(ACTIVE)
  createdById           String           @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("DestinationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  cities       DestinationCity[]
  hotels       Hotel[]
  sightseeings Sightseeing[]

  @@index([companyId, countryCode, normalizedName])
  @@index([companyId, destinationType, status, deletedAt])
  @@index([companyId, createdAt])
  @@index([createdById])
  @@map("destinations")
}

model DestinationCity {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @db.Uuid
  destinationId String   @db.Uuid
  cityId        String   @db.Uuid
  sequence      Int
  createdAt     DateTime @default(now())

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  city        City        @relation(fields: [cityId], references: [id], onDelete: Restrict)

  @@unique([destinationId, cityId])
  @@unique([destinationId, sequence])
  @@index([companyId, cityId])
  @@map("destination_cities")
}

/// A reusable hotel content record. A master entity in its own right — never
/// merged with Vendor. May later be referenced by quotations and bookings.
model Hotel {
  id                    String           @id @default(uuid()) @db.Uuid
  companyId             String           @db.Uuid
  destinationId         String           @db.Uuid
  cityId                String           @db.Uuid
  name                  String           @db.VarChar(200)
  normalizedName        String           @db.VarChar(200)
  starCategory          Int?
  starRating            Decimal?         @db.Decimal(2, 1)
  propertyType          String?          @db.VarChar(80)
  address               String?          @db.VarChar(1000)
  landmark              String?          @db.VarChar(200)
  postalCode            String?          @db.VarChar(20)
  latitude              Decimal?         @db.Decimal(9, 6)
  longitude             Decimal?         @db.Decimal(9, 6)
  contactName           String?          @db.VarChar(160)
  phone                 String?          @db.VarChar(40)
  email                 String?          @db.VarChar(255)
  website               String?          @db.VarChar(255)
  reviewLink            String?          @db.VarChar(500)
  checkInTime           String?          @db.VarChar(5)
  checkOutTime          String?          @db.VarChar(5)
  description           String?          @db.Text
  amenities             String?          @db.Text
  internalNotes         String?          @db.Text
  externalCode          String?          @db.VarChar(80)
  isDefaultForCity      Boolean          @default(false)
  isFeatured            Boolean          @default(false)
  sortOrder             Int              @default(0)
  imageStorageProvider  StorageProvider?
  imageBucket           String?          @db.VarChar(255)
  imageObjectKey        String?          @db.VarChar(1000)
  imageFileName         String?          @db.VarChar(255)
  imageMimeType         String?          @db.VarChar(120)
  imageFileSize         Int?
  imageConfirmedAt      DateTime?
  pendingImageObjectKey String?          @db.VarChar(1000)
  pendingImageFileName  String?          @db.VarChar(255)
  pendingImageMimeType  String?          @db.VarChar(120)
  pendingImageFileSize  Int?
  status                MasterStatus     @default(ACTIVE)
  createdById           String           @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  destination Destination     @relation(fields: [destinationId], references: [id], onDelete: Restrict)
  city        City            @relation(fields: [cityId], references: [id], onDelete: Restrict)
  createdBy   User            @relation("HotelCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  roomTypes   HotelRoomType[]
  mealPlans   HotelMealPlan[]

  quotationTemplateOptions QuotationTemplateHotelOption[]
  quotationVersionOptions  QuotationVersionHotelOption[]

  @@index([companyId, cityId, normalizedName])
  @@index([companyId, destinationId])
  @@index([companyId, status, deletedAt])
  @@index([companyId, cityId, isDefaultForCity])
  @@index([createdById])
  @@map("hotels")
}

model HotelRoomType {
  id            String       @id @default(uuid()) @db.Uuid
  companyId     String       @db.Uuid
  hotelId       String       @db.Uuid
  name          String       @db.VarChar(160)
  code          String?      @db.VarChar(40)
  description   String?      @db.VarChar(2000)
  maxAdults     Int?
  maxChildren   Int?
  maxOccupancy  Int?
  bedType       String?      @db.VarChar(80)
  numberOfBeds  Int?
  roomSize      String?      @db.VarChar(60)
  viewType      String?      @db.VarChar(80)
  baseCost      Decimal?     @db.Decimal(14, 2)
  sellingPrice  Decimal?     @db.Decimal(14, 2)
  currency      String       @default("INR") @db.VarChar(3)
  taxPercentage Decimal?     @db.Decimal(5, 2)
  internalNotes String?      @db.VarChar(2000)
  status        MasterStatus @default(ACTIVE)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  quotationTemplateOptions QuotationTemplateHotelOption[]
  quotationVersionOptions  QuotationVersionHotelOption[]

  @@index([companyId, hotelId])
  @@index([hotelId, sortOrder])
  @@map("hotel_room_types")
}

model HotelMealPlan {
  id            String            @id @default(uuid()) @db.Uuid
  companyId     String            @db.Uuid
  hotelId       String            @db.Uuid
  name          String            @db.VarChar(160)
  code          String?           @db.VarChar(40)
  type          HotelMealPlanType @default(CUSTOM)
  description   String?           @db.VarChar(2000)
  baseCost      Decimal?          @db.Decimal(14, 2)
  sellingPrice  Decimal?          @db.Decimal(14, 2)
  currency      String            @default("INR") @db.VarChar(3)
  internalNotes String?           @db.VarChar(2000)
  status        MasterStatus      @default(ACTIVE)
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  quotationTemplateOptions QuotationTemplateHotelOption[]
  quotationVersionOptions  QuotationVersionHotelOption[]

  @@index([companyId, hotelId])
  @@index([hotelId, sortOrder])
  @@map("hotel_meal_plans")
}

model Airline {
  id                   String           @id @default(uuid()) @db.Uuid
  companyId            String           @db.Uuid
  name                 String           @db.VarChar(200)
  normalizedName       String           @db.VarChar(200)
  iataCode             String?          @db.VarChar(2)
  icaoCode             String?          @db.VarChar(3)
  countryCode          String?          @db.Char(2)
  countryName          String?          @db.VarChar(120)
  website              String?          @db.VarChar(255)
  internalNotes        String?          @db.Text
  logoStorageProvider  StorageProvider?
  logoBucket           String?          @db.VarChar(255)
  logoObjectKey        String?          @db.VarChar(1000)
  logoFileName         String?          @db.VarChar(255)
  logoMimeType         String?          @db.VarChar(120)
  logoFileSize         Int?
  logoConfirmedAt      DateTime?
  pendingLogoObjectKey String?          @db.VarChar(1000)
  pendingLogoFileName  String?          @db.VarChar(255)
  pendingLogoMimeType  String?          @db.VarChar(120)
  pendingLogoFileSize  Int?
  status               MasterStatus     @default(ACTIVE)
  createdById          String           @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("AirlineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@index([companyId, normalizedName])
  @@index([companyId, status, deletedAt])
  @@index([companyId, countryCode])
  @@index([createdById])
  @@map("airlines")
}

/// A reusable sightseeing attraction, tour, transfer or activity.
///
/// Scope follows the reference CRM's Sightseeing Master: reusable itinerary
/// content grouped by Destination and City. It is NOT a ticketing, inventory,
/// availability or guide-scheduling system, and it carries no pricing — the
/// reference form has no price field.
model Sightseeing {
  id            String @id @default(uuid()) @db.Uuid
  companyId     String @db.Uuid
  destinationId String @db.Uuid
  cityId        String @db.Uuid

  title           String @db.VarChar(250)
  /// Lower-cased title backing case-insensitive search.
  normalizedTitle String @db.VarChar(250)

  /// Manual ordering within a city. The reference restarts numbering per city
  /// and tolerates gaps, so this is not unique.
  sequence Int @default(1)

  /// Duration in hours, e.g. 2.5 for 2h30m. Nullable — often blank.
  estimatedHours     Decimal? @db.Decimal(5, 2)
  /// Recommended local start time as HH:mm. Stored as text because it is a
  /// wall-clock suggestion, not an instant.
  suggestedStartTime String?  @db.VarChar(5)

  /// Rich-text HTML from the editors.
  description String? @db.Text
  remarks     String? @db.Text

  imageStorageProvider  StorageProvider?
  imageBucket           String?          @db.VarChar(255)
  imageObjectKey        String?          @db.VarChar(1000)
  imageFileName         String?          @db.VarChar(255)
  imageMimeType         String?          @db.VarChar(120)
  imageFileSize         Int?
  imageConfirmedAt      DateTime?
  pendingImageObjectKey String?          @db.VarChar(1000)
  pendingImageFileName  String?          @db.VarChar(255)
  pendingImageMimeType  String?          @db.VarChar(120)
  pendingImageFileSize  Int?

  status      MasterStatus @default(ACTIVE)
  createdById String       @db.Uuid
  updatedById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Restrict: a destination or city still used by sightseeing content cannot
  // be removed out from under it.
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Restrict)
  city        City        @relation(fields: [cityId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("SightseeingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?       @relation("SightseeingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@unique([companyId, cityId, normalizedTitle])
  @@index([companyId, status, deletedAt])
  @@index([companyId, destinationId, cityId, sequence])
  @@index([companyId, cityId, sequence])
  @@index([companyId, normalizedTitle])
  @@index([destinationId])
  @@index([cityId])
  @@index([createdById])
  @@index([updatedById])
  @@map("sightseeings")
}

/// A reusable optional extra sold alongside a trip (visa assistance, insurance,
/// arrival cards, ferry service…).
///
/// The reference form exposes exactly four fields — name, description, price
/// and an active toggle — so there is deliberately no category, pricing basis,
/// tax, internal cost or image here.
model AddOnService {
  id             String  @id @default(uuid()) @db.Uuid
  companyId      String  @db.Uuid
  name           String  @db.VarChar(200)
  normalizedName String  @db.VarChar(200)
  /// Rich-text HTML from the description editor.
  description    String? @db.Text

  /// Single public price. The reference shows one price with no cost split,
  /// which is why this module has no costing permissions.
  price    Decimal @default(0) @db.Decimal(14, 2)
  currency String  @default("INR") @db.VarChar(3)

  status      MasterStatus @default(ACTIVE)
  createdById String       @db.Uuid
  updatedById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("AddOnServiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?   @relation("AddOnServiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@unique([companyId, normalizedName])
  @@index([companyId, status, deletedAt])
  @@index([companyId, normalizedName])
  @@index([createdById])
  @@index([updatedById])
  @@map("add_on_services")
}

/// A cruise product offered to travellers, with its sellable room types.
///
/// Scope is deliberately narrow (Phase 13C): the reference CRM's Cruise Master
/// is a catalogue entry — name, description, image and room types. It is not an
/// itinerary, sailing-schedule or deck-plan engine.
model Cruise {
  id             String  @id @default(uuid()) @db.Uuid
  companyId      String  @db.Uuid
  name           String  @db.VarChar(200)
  /// Lower-cased name backing case-insensitive search and per-tenant uniqueness.
  normalizedName String  @db.VarChar(200)
  /// Rich-text HTML from the description editor.
  description    String? @db.Text

  // Private media. Mirrors the Hotel/Airline two-phase upload: the pending*
  // columns hold an approved-but-unconfirmed object until the client confirms.
  imageStorageProvider  StorageProvider?
  imageBucket           String?          @db.VarChar(255)
  imageObjectKey        String?          @db.VarChar(1000)
  imageFileName         String?          @db.VarChar(255)
  imageMimeType         String?          @db.VarChar(120)
  imageFileSize         Int?
  imageConfirmedAt      DateTime?
  pendingImageObjectKey String?          @db.VarChar(1000)
  pendingImageFileName  String?          @db.VarChar(255)
  pendingImageMimeType  String?          @db.VarChar(120)
  pendingImageFileSize  Int?

  status      MasterStatus @default(ACTIVE)
  createdById String       @db.Uuid
  updatedById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User             @relation("CruiseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?            @relation("CruiseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  roomTypes CruiseRoomType[]

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@unique([companyId, normalizedName])
  @@index([companyId, status, deletedAt])
  @@index([companyId, normalizedName])
  @@index([createdById])
  @@index([updatedById])
  @@map("cruises")
}

/// A sellable cabin/room category on a cruise (Interior, Ocean View, Suite…).
model CruiseRoomType {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @db.Uuid
  cruiseId    String   @db.Uuid
  name        String   @db.VarChar(160)
  description String?  @db.VarChar(2000)
  /// Nullable: the reference allows a room type with no price yet, which is
  /// why the list can render "No pricing information available".
  price       Decimal? @db.Decimal(14, 2)
  currency    String   @default("INR") @db.VarChar(3)

  status    MasterStatus @default(ACTIVE)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Cascade: a room type has no meaning without its cruise, and cruises are
  // only ever soft-archived, so this never destroys historical data.
  cruise  Cruise  @relation(fields: [cruiseId], references: [id], onDelete: Cascade)

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@index([companyId, cruiseId])
  @@index([cruiseId, sortOrder])
  @@map("cruise_room_types")
}

/// A vehicle category offered for transfers and sightseeing.
///
/// This is a catalogue master (name/type/capacity), NOT fleet management: no
/// drivers, registrations, maintenance, GPS or scheduling.
model Vehicle {
  id             String  @id @default(uuid()) @db.Uuid
  companyId      String  @db.Uuid
  name           String  @db.VarChar(200)
  normalizedName String  @db.VarChar(200)
  /// Free text in the reference ("Luxury SUV", "AC Coach"); the list filter is
  /// built from the distinct values a tenant has actually used.
  vehicleType    String  @db.VarChar(120)
  /// Seats available to travellers. Nullable — the reference leaves it optional.
  capacity       Int?
  description    String? @db.Text

  imageStorageProvider  StorageProvider?
  imageBucket           String?          @db.VarChar(255)
  imageObjectKey        String?          @db.VarChar(1000)
  imageFileName         String?          @db.VarChar(255)
  imageMimeType         String?          @db.VarChar(120)
  imageFileSize         Int?
  imageConfirmedAt      DateTime?
  pendingImageObjectKey String?          @db.VarChar(1000)
  pendingImageFileName  String?          @db.VarChar(255)
  pendingImageMimeType  String?          @db.VarChar(120)
  pendingImageFileSize  Int?

  status      MasterStatus @default(ACTIVE)
  createdById String       @db.Uuid
  updatedById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?   @relation("VehicleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  quotationVersionServices  QuotationVersionService[]
  quotationTemplateServices QuotationTemplateService[]

  @@unique([companyId, normalizedName])
  @@index([companyId, status, deletedAt])
  @@index([companyId, vehicleType])
  @@index([companyId, normalizedName])
  @@index([createdById])
  @@index([updatedById])
  @@map("vehicles")
}

// ---------------------------------------------------------------------------
// Authorisation
// ---------------------------------------------------------------------------

/// A named set of permissions within one company.
model Role {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @db.Uuid
  name        String  @db.VarChar(60)
  description String? @db.VarChar(500)

  /// Higher wins. Used to stop a user assigning a role above their own.
  hierarchyLevel Int @default(0)

  /// System roles are seeded per company and protected from deletion.
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId, hierarchyLevel])
  @@map("roles")
}

/// The global permission catalogue. Not tenant scoped — the same keys exist
/// for every company; only the grants differ.
model Permission {
  id          String @id @default(uuid()) @db.Uuid
  /// `<module>.<action>`, e.g. `users.create`.
  key         String @unique @db.VarChar(80)
  module      String @db.VarChar(40)
  action      String @db.VarChar(40)
  description String @db.VarChar(500)

  /// False for modules that are planned but not built. Must never be granted.
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())

  roles     RolePermission[]
  templates PermissionTemplatePermission[]

  @@index([module])
  @@index([isAvailable])
  @@map("permissions")
}

/// Join table: which permissions a role grants.
model RolePermission {
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// A reusable, company-scoped permission preset applied on top of a role.
model PermissionTemplate {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @db.Uuid
  name        String         @db.VarChar(60)
  description String?        @db.VarChar(500)
  status      TemplateStatus @default(ACTIVE)

  /// Nullable so removing the author does not remove the template.
  createdById String? @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company     Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User?                          @relation("PermissionTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  users       User[]
  permissions PermissionTemplatePermission[]

  @@unique([companyId, name])
  @@index([companyId, status])
  @@index([companyId, deletedAt])
  @@index([createdById])
  @@map("permission_templates")
}

/// Join table: which permissions a template grants.
model PermissionTemplatePermission {
  templateId   String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  template   PermissionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  permission Permission         @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([templateId, permissionId])
  @@index([permissionId])
  @@map("permission_template_permissions")
}

// ---------------------------------------------------------------------------
// Credentials — tenancy inherited through User
// ---------------------------------------------------------------------------

/// An authenticated browser session. Opaque server-backed token.
model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  /// SHA-256 of the raw token, which is only ever held by the client cookie.
  /// A database leak therefore cannot be replayed as a session.
  tokenHash String @unique @db.VarChar(64)

  expiresAt DateTime
  revokedAt DateTime?

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(512)

  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

/// A one-time email-verification code. Hashed, single use, attempt limited.
model EmailVerificationOtp {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  /// Hash of the six-digit code. The plaintext OTP is never persisted.
  otpHash String @db.VarChar(64)

  expiresAt DateTime
  usedAt    DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("email_verification_otps")
}

/// A single-use password-reset token. Hashed at rest.
model PasswordResetToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  /// SHA-256 of the token embedded in the reset link.
  tokenHash String @unique @db.VarChar(64)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Append-only audit trail, scoped to a company.
///
/// Actor and target are SetNull rather than Cascade: the record of what
/// happened must outlive the accounts involved.
model ActivityLog {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @db.Uuid

  /// Null for system-originated events with no signed-in actor.
  actorUserId  String? @db.Uuid
  /// Null when the action does not target a specific user.
  targetUserId String? @db.Uuid

  action     ActivityAction
  entityType String         @db.VarChar(40)
  entityId   String?        @db.Uuid

  /// Safe contextual detail only. Never credentials, tokens, OTPs or full
  /// request bodies.
  metadata Json?

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(512)

  createdAt DateTime @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser  User?   @relation("ActivityLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User?   @relation("ActivityLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([companyId, actorUserId])
  @@index([companyId, entityType])
  @@map("activity_logs")
}

