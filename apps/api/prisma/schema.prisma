// ---------------------------------------------------------------------------
// Booking operations — immutable quotation source plus operational records
// ---------------------------------------------------------------------------

model BookingCounter {
  companyId    String  @db.Uuid
  year         Int
  bookingValue Int     @default(0)
  paymentValue Int     @default(0)
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, year])
  @@map("booking_counters")
}

model Booking {
  id                       String               @id @default(uuid()) @db.Uuid
  companyId                String               @db.Uuid
  customerId               String?              @db.Uuid
  bookingNumber            String               @db.VarChar(24)
  queryId                  String?              @db.Uuid
  quotationId              String?              @unique @db.Uuid
  quotationVersionId       String?              @unique @db.Uuid
  customerName             String               @db.VarChar(120)
  customerEmail            String?              @db.VarChar(255)
  customerPhone            String               @db.VarChar(32)
  destinationSummary       String               @db.VarChar(500)
  travelStartDate          DateTime?            @db.Date
  travelEndDate            DateTime?            @db.Date
  rooms                    Int                  @default(1)
  adults                   Int                  @default(1)
  childrenWithBed          Int                  @default(0)
  childrenWithoutBed       Int                  @default(0)
  infants                  Int                  @default(0)
  currency                 String               @default("INR") @db.VarChar(3)
  bookingStatus            BookingStatus        @default(PENDING_CONFIRMATION)
  operationalStatus        OperationalStatus    @default(NOT_STARTED)
  paymentStatus            BookingPaymentStatus @default(UNPAID)
  totalSellingAmount       Decimal              @default(0) @db.Decimal(14, 2)
  totalCustomerPaid        Decimal              @default(0) @db.Decimal(14, 2)
  totalCustomerOutstanding Decimal              @default(0) @db.Decimal(14, 2)
  totalCost                Decimal              @default(0) @db.Decimal(14, 2)
  grossProfit              Decimal              @default(0) @db.Decimal(14, 2)
  profitMarginPercentage   Decimal              @default(0) @db.Decimal(8, 4)
  bookedById               String               @db.Uuid
  assignedToId             String?              @db.Uuid
  sourceTitle              String?              @db.VarChar(200)
  sourceTerms              Json?
  manualCreationReason     String?              @db.VarChar(2000)
  acceptedAt               DateTime?
  confirmedAt              DateTime?
  cancelledAt              DateTime?
  completedAt              DateTime?
  cancellationReason       String?              @db.VarChar(2000)
  internalNotes            String?              @db.VarChar(4000)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deletedAt                DateTime?

  company                Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer               Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  query                  Query?                     @relation(fields: [queryId], references: [id], onDelete: Restrict)
  quotation              Quotation?                 @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  quotationVersion       QuotationVersion?          @relation(fields: [quotationVersionId], references: [id], onDelete: Restrict)
  bookedBy               User                       @relation("BookingBookedBy", fields: [bookedById], references: [id], onDelete: Restrict)
  assignedTo             User?                      @relation("BookingAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  travellers             BookingTraveller[]
  services               BookingService[]
  itinerary              BookingItineraryDay[]
  paymentSchedules       BookingPaymentSchedule[]
  payments               BookingPayment[]
  costs                  BookingCost[]
  documents              BookingDocument[]
  notes                  BookingNote[]
  statusHistory          BookingStatusHistory[]
  assignmentHistory      BookingAssignmentHistory[]
  emailLogs              BookingEmailLog[]
  customerCommunications CustomerCommunication[]

  @@unique([companyId, bookingNumber])
  @@index([companyId, queryId, deletedAt])
  @@index([companyId, customerId, deletedAt])
  @@index([companyId, bookingStatus, deletedAt])
  @@index([companyId, operationalStatus, deletedAt])
  @@index([companyId, paymentStatus, deletedAt])
  @@index([companyId, assignedToId, deletedAt])
  @@index([companyId, travelStartDate])
  @@index([companyId, createdAt])
  @@map("bookings")
}

model BookingTraveller {
  id                      String        @id @default(uuid()) @db.Uuid
  companyId               String        @db.Uuid
  bookingId               String        @db.Uuid
  travellerType           TravellerType
  title                   String        @db.VarChar(20)
  firstName               String        @db.VarChar(100)
  middleName              String?       @db.VarChar(100)
  lastName                String        @db.VarChar(100)
  gender                  String?       @db.VarChar(30)
  dateOfBirth             DateTime?     @db.Date
  nationality             String?       @db.VarChar(80)
  email                   String?       @db.VarChar(255)
  phone                   String?       @db.VarChar(32)
  passportNumberEncrypted String?       @db.Text
  passportKeyVersion      String?       @db.VarChar(30)
  passportCountry         String?       @db.VarChar(80)
  passportIssuedAt        DateTime?     @db.Date
  passportExpiresAt       DateTime?     @db.Date
  visaStatus              VisaStatus    @default(NOT_STARTED)
  specialRequirements     String?       @db.VarChar(2000)
  isPrimaryTraveller      Boolean       @default(false)
  sequence                Int
  createdById             String        @db.Uuid
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  deletedAt               DateTime?

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking   Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy User              @relation("BookingTravellerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  documents BookingDocument[]

  @@unique([bookingId, sequence])
  @@index([companyId, bookingId, deletedAt])
  @@index([companyId, passportExpiresAt])
  @@map("booking_travellers")
}

model BookingService {
  id                    String                    @id @default(uuid()) @db.Uuid
  companyId             String                    @db.Uuid
  bookingId             String                    @db.Uuid
  serviceType           ServiceType
  name                  String                    @db.VarChar(200)
  description           String?                   @db.VarChar(4000)
  city                  String?                   @db.VarChar(120)
  serviceDate           DateTime?                 @db.Date
  startDate             DateTime?                 @db.Date
  endDate               DateTime?                 @db.Date
  confirmationStatus    ServiceConfirmationStatus @default(PENDING)
  confirmationNumber    String?                   @db.VarChar(255)
  supplierName          String?                   @db.VarChar(200)
  supplierReference     String?                   @db.VarChar(255)
  customerSellingAmount Decimal                   @default(0) @db.Decimal(14, 2)
  internalCostSnapshot  Decimal                   @default(0) @db.Decimal(14, 2)
  paymentDueAt          DateTime?
  cancellationDeadline  DateTime?
  notes                 String?                   @db.VarChar(2000)
  sequence              Int
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  deletedAt             DateTime?

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking   Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  costs     BookingCost[]
  documents BookingDocument[]

  @@unique([bookingId, sequence])
  @@index([companyId, bookingId, deletedAt])
  @@index([companyId, confirmationStatus])
  @@map("booking_services")
}

model BookingItineraryDay {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @db.Uuid
  bookingId         String    @db.Uuid
  dayNumber         Int
  date              DateTime? @db.Date
  title             String    @db.VarChar(200)
  destination       String    @db.VarChar(120)
  description       String    @db.VarChar(8000)
  meals             String?   @db.VarChar(500)
  overnightLocation String?   @db.VarChar(120)
  sequence          Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, sequence])
  @@index([companyId, bookingId])
  @@map("booking_itinerary_days")
}

model BookingPaymentSchedule {
  id                String                @id @default(uuid()) @db.Uuid
  companyId         String                @db.Uuid
  bookingId         String                @db.Uuid
  installmentNumber Int
  label             String                @db.VarChar(120)
  amount            Decimal               @db.Decimal(14, 2)
  dueDate           DateTime              @db.Date
  status            PaymentScheduleStatus @default(PENDING)
  notes             String?               @db.VarChar(2000)
  createdById       String                @db.Uuid
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking   Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy User             @relation("BookingScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
