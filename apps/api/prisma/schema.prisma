// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

/// A person who can sign in. Belongs to exactly one company.
model User {
  id                   String  @id @default(uuid()) @db.Uuid
  companyId            String  @db.Uuid
  roleId               String  @db.Uuid
  permissionTemplateId String? @db.Uuid

  /// Login handle, unique per company (not globally).
  username String @db.VarChar(40)
  fullName String @db.VarChar(120)

  /// Address as the user typed it, preserved for display.
  email           String  @db.VarChar(255)
  /// Lowercased, trimmed form used for lookup and uniqueness.
  ///
  /// GLOBALLY UNIQUE BY DESIGN: login accepts only email + password, with no
  /// tenant selector, so an address must resolve to exactly one account.
  /// Trade-off: one person cannot hold accounts at two agencies with the same
  /// address. Revisiting that would require a company selector at login.
  normalizedEmail String  @unique @db.VarChar(255)
  phone           String? @db.VarChar(32)

  /// Argon2id digest. No plaintext password is ever stored.
  passwordHash String @db.VarChar(255)

  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  /// Forces a password change on next sign-in (admin-created accounts).
  mustChangePassword Boolean @default(false)

  /// Brute-force controls, reset on every successful login.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  /// When the password was last changed. Audit data, and a reference point for
  /// invalidating anything issued before a reset. Null for never-changed.
  passwordChangedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft deletion. Non-null rows are excluded from normal reads.
  deletedAt DateTime?

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Restrict: a role still assigned to a user cannot be deleted.
  role               Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  // SetNull: deleting a template must never delete the users using it.
  permissionTemplate PermissionTemplate? @relation(fields: [permissionTemplateId], references: [id], onDelete: SetNull)

  sessions                    Session[]
  emailVerificationOtps       EmailVerificationOtp[]
  passwordResetTokens         PasswordResetToken[]
  createdTemplates            PermissionTemplate[]       @relation("PermissionTemplateCreatedBy")
  activityLogsAsActor         ActivityLog[]              @relation("ActivityLogActor")
  activityLogsAsTarget        ActivityLog[]              @relation("ActivityLogTarget")
  queriesCreated              Query[]                    @relation("QueryCreatedBy")
  queriesAssigned             Query[]                    @relation("QueryAssignedTo")
  queryNotes                  QueryNote[]                @relation("QueryNoteAuthor")
  queryStagesChanged          QueryStageHistory[]        @relation("QueryStageChangedBy")
  queryAssignmentsMade        QueryAssignmentHistory[]   @relation("QueryAssignedBy")
  queryAssignmentsFrom        QueryAssignmentHistory[]   @relation("QueryPreviousAssignee")
  queryAssignmentsTo          QueryAssignmentHistory[]   @relation("QueryNewAssignee")
  queryFollowUpsAssigned      QueryFollowUp[]            @relation("QueryFollowUpAssigned")
  queryFollowUpsCreated       QueryFollowUp[]            @relation("QueryFollowUpCreated")
  queryFollowUpsCompleted     QueryFollowUp[]            @relation("QueryFollowUpCompleted")
  queryFollowUpsCancelled     QueryFollowUp[]            @relation("QueryFollowUpCancelled")
  reminderRulesCreated        ReminderRule[]             @relation("ReminderRuleCreatedBy")
  reminderRulesAssigned       ReminderRule[]             @relation("ReminderRuleFixedUser")
  notificationsReceived       Notification[]             @relation("NotificationRecipient")
  notificationPreference      NotificationPreference?
  reminderEscalationsReceived ReminderEscalation[]       @relation("ReminderEscalatedTo")
  quotationTemplatesCreated   QuotationTemplate[]        @relation("QuotationTemplateCreatedBy")
  quotationsCreated           Quotation[]                @relation("QuotationCreatedBy")
  quotationVersionsCreated    QuotationVersion[]         @relation("QuotationVersionCreatedBy")
  quotationDocumentsGenerated QuotationDocument[]        @relation("QuotationDocumentGeneratedBy")
  quotationEmailsSent         QuotationEmailLog[]        @relation("QuotationEmailSentBy")
  bookingsCreated             Booking[]                  @relation("BookingBookedBy")
  bookingsAssigned            Booking[]                  @relation("BookingAssignedTo")
  bookingTravellersCreated    BookingTraveller[]         @relation("BookingTravellerCreatedBy")
  bookingSchedulesCreated     BookingPaymentSchedule[]   @relation("BookingScheduleCreatedBy")
  bookingPaymentsRecorded     BookingPayment[]           @relation("BookingPaymentRecordedBy")
  bookingPaymentsReversed     BookingPayment[]           @relation("BookingPaymentReversedBy")
  bookingCostsRecorded        BookingCost[]              @relation("BookingCostRecordedBy")
  bookingDocumentsUploaded    BookingDocument[]          @relation("BookingDocumentUploadedBy")
  bookingNotesAuthored        BookingNote[]              @relation("BookingNoteAuthor")
  bookingStatusesChanged      BookingStatusHistory[]     @relation("BookingStatusChangedBy")
  bookingAssignmentsMade      BookingAssignmentHistory[] @relation("BookingAssignedBy")
  bookingAssignmentsFrom      BookingAssignmentHistory[] @relation("BookingPreviousAssignee")
  bookingAssignmentsTo        BookingAssignmentHistory[] @relation("BookingNewAssignee")
  bookingEmailsSent           BookingEmailLog[]          @relation("BookingEmailSentBy")
  customersCreated            Customer[]                 @relation("CustomerCreatedBy")
  customersAssigned           Customer[]                 @relation("CustomerAssignedTo")
  customerNotesAuthored       CustomerNote[]             @relation("CustomerNoteAuthor")
  customerCommunicationsMade  CustomerCommunication[]    @relation("CustomerCommunicationBy")
  customerDocumentsUploaded   CustomerDocument[]         @relation("CustomerDocumentUploadedBy")
  customerMergesPerformed     CustomerMergeHistory[]     @relation("CustomerMergePerformedBy")
  vendorsCreated              Vendor[]                   @relation("VendorCreatedBy")
  vendorsAssigned             Vendor[]                   @relation("VendorAssignedTo")
  vendorServicesCreated       VendorService[]            @relation("VendorServiceCreatedBy")
  vendorDocumentsUploaded     VendorDocument[]           @relation("VendorDocumentUploadedBy")
  vendorNotesAuthored         VendorNote[]               @relation("VendorNoteAuthor")
  vendorPayablesCreated       VendorPayable[]            @relation("VendorPayableCreatedBy")
  vendorPaymentsRecorded      VendorPayment[]            @relation("VendorPaymentRecordedBy")
  vendorPaymentsReversed      VendorPayment[]            @relation("VendorPaymentReversedBy")
  citiesCreated               City[]                     @relation("CityCreatedBy")
  destinationsCreated         Destination[]              @relation("DestinationCreatedBy")
  hotelsCreated               Hotel[]                    @relation("HotelCreatedBy")
  airlinesCreated             Airline[]                  @relation("AirlineCreatedBy")
  cruisesCreated              Cruise[]                   @relation("CruiseCreatedBy")
  cruisesUpdated              Cruise[]                   @relation("CruiseUpdatedBy")
  vehiclesCreated             Vehicle[]                  @relation("VehicleCreatedBy")
  vehiclesUpdated             Vehicle[]                  @relation("VehicleUpdatedBy")
  sightseeingsCreated         Sightseeing[]              @relation("SightseeingCreatedBy")
  sightseeingsUpdated         Sightseeing[]              @relation("SightseeingUpdatedBy")
  addOnServicesCreated        AddOnService[]             @relation("AddOnServiceCreatedBy")
  addOnServicesUpdated        AddOnService[]             @relation("AddOnServiceUpdatedBy")

  @@unique([companyId, username])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, deletedAt])
  @@index([roleId])
  @@index([permissionTemplateId])
