model QuotationVersionService {
  id                 String           @id @default(uuid()) @db.Uuid
  companyId          String           @db.Uuid
  quotationVersionId String           @db.Uuid
  serviceType        ServiceType
  // Optional master references (Phase 14). Snapshot columns below stay
  // authoritative: these link a row to its catalogue entry without ever
  // becoming the source of rendered text or price.
  airlineId          String?          @db.Uuid
  cruiseId           String?          @db.Uuid
  cruiseRoomTypeId   String?          @db.Uuid
  vehicleId          String?          @db.Uuid
  sightseeingId      String?          @db.Uuid
  addOnServiceId     String?          @db.Uuid
  name               String           @db.VarChar(200)
  description        String?          @db.VarChar(4000)
  dayNumber          Int?
  city               String?          @db.VarChar(120)
  quantity           Decimal          @default(1) @db.Decimal(10, 2)
  unitCost           Decimal          @default(0) @db.Decimal(14, 2)
  unitSellingPrice   Decimal          @default(0) @db.Decimal(14, 2)
  totalCost          Decimal          @default(0) @db.Decimal(14, 2)
  totalSellingPrice  Decimal          @default(0) @db.Decimal(14, 2)
  taxCategory        String?          @db.VarChar(80)
  notes              String?          @db.VarChar(2000)
  sequence           Int
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotationVersion   QuotationVersion @relation(fields: [quotationVersionId], references: [id], onDelete: Cascade)
  // SetNull everywhere: archiving or deleting a master must never destroy or
  // rewrite a saved quotation line.
  airline            Airline?         @relation(fields: [airlineId], references: [id], onDelete: SetNull)
  cruise             Cruise?          @relation(fields: [cruiseId], references: [id], onDelete: SetNull)
  cruiseRoomType     CruiseRoomType?  @relation(fields: [cruiseRoomTypeId], references: [id], onDelete: SetNull)
  vehicle            Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  sightseeing        Sightseeing?     @relation(fields: [sightseeingId], references: [id], onDelete: SetNull)
  addOnService       AddOnService?    @relation(fields: [addOnServiceId], references: [id], onDelete: SetNull)

  @@unique([quotationVersionId, sequence])
  @@index([companyId, quotationVersionId])
  @@index([companyId, serviceType])
  @@index([airlineId])
  @@index([cruiseId])
  @@index([cruiseRoomTypeId])
  @@index([vehicleId])
  @@index([sightseeingId])
  @@index([addOnServiceId])
  @@map("quotation_version_services")
}

